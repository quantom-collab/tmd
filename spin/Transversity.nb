   3.830265825835352*^9},ExpressionUUID->"f4cdbab8-ce09-4f33-952b-\
1f5ce5ade1f1"],

Cell["\<\
        Nfav*Gamma(1 + \[Beta]fav)*(-((NubDSS*Gamma(aubDSS + n + \
\[Alpha]fav)*(Hypergeometric2F1(aubDSS + n + \[Alpha]fav,-\[Beta]ubDSS,1 + \
aubDSS + n + \[Alpha]fav + \[Beta]fav,1) + 
     -           \[Gamma]ubDSS*Hypergeometric2F1(aubDSS + n + \[Alpha]fav,-\
\[Beta]ubDSS - \[Delta]ubDSS,1 + aubDSS + n + \[Alpha]fav + \[Beta]fav,1)))/
     -       ((Beta(2 + \[Alpha]ubDSS,1 + \[Beta]ubDSS) + \
\[Gamma]ubDSS*Beta(2 + \[Alpha]ubDSS,1 + \[Beta]ubDSS + \
\[Delta]ubDSS))*Gamma(1 + aubDSS + n + \[Alpha]fav + \[Beta]fav))) + 
     -    (NupDSS*Gamma(aupDSS + n + \[Alpha]fav)*(Hypergeometric2F1(aupDSS + \
n + \[Alpha]fav,-\[Beta]upDSS,1 + aupDSS + n + \[Alpha]fav + \[Beta]fav,1) + 
     -         \[Gamma]upDSS*Hypergeometric2F1(aupDSS + n + \[Alpha]fav,-\
\[Beta]upDSS - \[Delta]upDSS,1 + aupDSS + n + \[Alpha]fav + \[Beta]fav,1)))/
     -     ((Beta(2 + \[Alpha]upDSS,1 + \[Beta]upDSS) + \[Gamma]upDSS*Beta(2 \
+ \[Alpha]upDSS,1 + \[Beta]upDSS + \[Delta]upDSS))*Gamma(1 + aupDSS + n + \
\[Alpha]fav + \[Beta]fav)))\
\>", "Output",
 CellChangeTimes->{{3.8279606337018757`*^9, 3.8279606417651*^9}, 
   3.827961877850808*^9, 
   3.830265826570373*^9},ExpressionUUID->"b1010a3d-98ec-4a22-8035-\
90701cf8717d"]
}, Open  ]],

