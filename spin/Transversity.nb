Cell[BoxData[{
 RowBox[{
  RowBox[{"CDKTuu", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"NuuT", " ", 
      SuperscriptBox["x", 
       RowBox[{"\[Alpha]uuT", "-", "1"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "\[Beta]uuT"], 
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[Alpha]uuT", "+", "\[Beta]uuT"}], ")"}], 
        RowBox[{"\[Alpha]uuT", "+", "\[Beta]uuT"}]], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", "\[Alpha]uuT", ")"}], "\[Alpha]uuT"], 
        SuperscriptBox[
         RowBox[{"(", "\[Beta]uuT", ")"}], "\[Beta]uuT"]}]], "*", 
      FractionBox["1", "2"], 
      RowBox[{"(", 
       RowBox[{"XUUf", "+", "XUUg"}], ")"}]}], ")"}], "//", "Expand"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CDKTdd", " ", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"NddT", " ", 
      SuperscriptBox["x", 
       RowBox[{"\[Alpha]ddT", "-", "1"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], "\[Beta]ddT"], 
