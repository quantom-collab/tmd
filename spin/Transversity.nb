Cell[BoxData[{
 RowBox[{
  RowBox[{"solns", " ", "=", " ", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xuv", " ", "\[Equal]", " ", 
        RowBox[{"xuu", "-", "xub"}]}], ",", 
       RowBox[{"xdv", " ", "\[Equal]", " ", 
        RowBox[{"xdd", "-", "xdb"}]}], ",", 
       RowBox[{"xSS", " ", "\[Equal]", " ", 
        RowBox[{
         RowBox[{"2", 
          RowBox[{"(", 
           RowBox[{"xub", "+", "xdb"}], ")"}]}], "+", "xss", "+", "xsb"}]}], 
       ",", 
       RowBox[{"xsp", " ", "\[Equal]", " ", 
        RowBox[{"xss", "+", "xsb"}]}], ",", 
       RowBox[{"xsm", " ", "\[Equal]", " ", 
        RowBox[{"xss", "-", "xsb"}]}], ",", 
       RowBox[{"x\[CapitalDelta]\[CapitalDelta]", " ", "\[Equal]", " ", 
        RowBox[{"xdb", "-", "xub"}]}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{
      "xuu", ",", "xdd", ",", "xss", ",", "xsb", ",", "xub", ",", "xdb"}], 
      "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"XUUf", " ", "=", " ", 
